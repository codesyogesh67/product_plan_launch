generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  product       String
  goal          String?
  timeframeDays Int?
  successMetrics String[] @default([])
  createdAt     DateTime @default(now())
  phases        Phase[]
}

model Phase {
  id           String @id @default(cuid())
  planId       String
  title        String
  order        Int
  durationDays Int
  steps        Step[]

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model Step {
  id          String     @id @default(cuid())
  phaseId     String
  title       String
  description String?
  status      StepStatus @default(TODO)
  dueDate     DateTime?
  metric      String?
  order       Int

  phase Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
}

enum StepStatus {
  TODO
  DOING
  DONE
}
